{
  "name": "effect-genserver",
  "type": "module",
  "version": "0.1.4",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "husky && effect-language-service patch",
    "check": "oxlint -c .oxlintrc.json --fix && pnpm tsc -b tsconfig.json",
    "test": "vitest run",
    "build": "tsc -b tsconfig.json",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "author": "Tim Smart <hello@timsmart.co>",
  "homepage": "https://github.com/tim-smart/effect-genserver",
  "repository": {
    "type": "git",
    "url": "https://github.com/tim-smart/effect-genserver.git"
  },
  "packageManager": "pnpm@10.28.0",
  "peerDependencies": {
    "effect": ">=4.0.0-beta.52 <4.0.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "^0.85.1",
    "@effect/vitest": "4.0.0-beta.58",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260428.1",
    "effect": "4.0.0-beta.59",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
